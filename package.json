{
  "name": "mapbox-contact-form",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start-proxy": "ng serve --proxy-config proxy.conf.json",
    "build": "ng build",
    "prestart": "node scripts/set-env.cjs",
    "watch": "ng build --watch --configuration development",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "yarn eslint --ignore-pattern *.cjs",
    "build:staging": "ng build --configuration=staging",
    "build:prod": "ng build --configuration=production"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^21.1.1",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@ngrx/effects": "^20.0.2",
    "@ngrx/signals": "^19.0.0",
    "@ngrx/store": "21.0.0",
    "date-fns": "^2.28.0",
    "jasmine-marbles": "0.9.2",
    "mapbox-gl": "3.15.0",
    "moment": "^2.30.1",
    "rxjs": "~7.5.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.5.1",
    "@angular-devkit/build-angular": "21.2.10",
    "@angular-eslint/builder": "20.1.1",
    "@angular-eslint/eslint-plugin": "20.1.1",
    "@angular/build": "^21.1.0",
    "@angular/cli": "^21.1.0",
    "@angular/compiler-cli": "^21.1.0",
    "@angular/platform-browser-dynamic": "^21.2.12",
    "@types/node": "^12.20.36 || ^14.14.41 || >=16.0.0",
    "@typescript-eslint/parser": "8.20.0",
    "angular-eslint": "21.2.0",
    "dotenv": "^17.4.2",
    "eslint": "9.10.0",
    "eslint-plugin-vitest": "^0.5.4",
    "jsdom": "^27.1.0",
    "ts-node": "~10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.50.1",
    "vitest": "^4.0.8"
  }
}
